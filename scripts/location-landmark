#!/usr/bin/env python3
"""
location-landmark - Detect when the user has stayed at a location long enough
to be considered a "landmark" and save it to Mnemosyne.

A landmark is a place where the user stays for >5 minutes within a 200m radius.
This runs as a cron job every 5 minutes, checking the location history.
"""

import json
import os
import subprocess
import sys
from datetime import datetime, timezone, timedelta
from math import radians, sin, cos, sqrt, atan2

HISTORY_FILE = os.path.expanduser("~/.hermes/location-history.jsonl")
LANDMARK_RADIUS = 200       # meters
LANDMARK_MIN_DURATION = 300 # seconds (5 minutes)
CHECK_WINDOW = 600          # seconds (10 minutes to look back)

def haversine(lat1, lon1, lat2, lon2):
    R = 6371000
    dlat = radians(lat2 - lat1)
    dlon = radians(lon2 - lon1)
    a = sin(dlat/2)**2 + cos(radians(lat1)) * cos(radians(lat2)) * sin(dlon/2)**2
    return R * 2 * atan2(sqrt(a), sqrt(1-a))

def load_recent_history():
    """Load history entries from the last CHECK_WINDOW seconds."""
    if not os.path.exists(HISTORY_FILE):
        return []
    cutoff = datetime.now(timezone.utc) - timedelta(seconds=CHECK_WINDOW)
    entries = []
    with open(HISTORY_FILE, "r") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                entry = json.loads(line)
                ts = datetime.fromisoformat(entry["timestamp"])
                if ts > cutoff:
                    entries.append(entry)
            except (json.JSONDecodeError, KeyError):
                continue
    return entries

def is_landmark(entries):
    """Check if the user has stayed in one area long enough to be a landmark."""
    if len(entries) < 2:
        return None

    # Use the centroid of all points
    avg_lat = sum(e["lat"] for e in entries) / len(entries)
    avg_lon = sum(e["lon"] for e in entries) / len(entries)

    # Check all points are within radius
    for e in entries:
        if haversine(avg_lat, avg_lon, e["lat"], e["lon"]) > LANDMARK_RADIUS:
            return None

    # Check duration
    timestamps = [datetime.fromisoformat(e["timestamp"]) for e in entries]
    duration = (max(timestamps) - min(timestamps)).total_seconds()
    if duration < LANDMARK_MIN_DURATION:
        return None

    return {
        "lat": round(avg_lat, 6),
        "lon": round(avg_lon, 6),
        "address": entries[-1].get("address", ""),
        "arrived": min(timestamps).isoformat(),
        "duration_minutes": round(duration / 60, 1)
    }

def is_new_landmark(landmark):
    """Check if this landmark is far enough from existing ones."""
    try:
        result = subprocess.run(
            ["python3", "-c", f"""
import json, sys
from math import radians, sin, cos, sqrt, atan2

def h(lat1, lon1, lat2, lon2):
    R = 6371000
    dlat = radians(lat2-lat1)
    dlon = radians(lon2-lon1)
    a = sin(dlat/2)**2 + cos(radians(lat1))*cos(radians(lat2))*sin(dlon/2)**2
    return R*2*(a**0.5)

# Would need to check against stored landmarks - simplified
print("NEW")
"""],
            capture_output=True, text=True, timeout=10
        )
    except Exception:
        pass
    return True  # Simplified - always new for now

def main():
    entries = load_recent_history()
    if not entries:
        print("[landmark] No recent history.")
        return

    landmark = is_landmark(entries)
    if landmark is None:
        print(f"[landmark] No landmark detected ({len(entries)} entries in window).")
        return

    print(f"[landmark] Detected: {landmark['address']} "
          f"({landmark['duration_minutes']} min)")

    # Output as JSON for potential Mnemosyne storage
    print(json.dumps(landmark))

if __name__ == "__main__":
    main()
