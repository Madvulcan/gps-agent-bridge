#!/usr/bin/env python3
"""
Prune raw location history to keep only the last 48 hours.
The compacted tiers in SQLite hold everything older.

This is the ONLY process that prunes location-history.jsonl.
location-updater now appends only (no self-pruning), so this
cron job must run reliably to prevent unbounded file growth.
"""
import json, os
from datetime import datetime, timezone, timedelta

HISTORY_FILE = os.path.expanduser("~/.hermes/location-history.jsonl")
KEEP_HOURS = 48

if not os.path.exists(HISTORY_FILE):
    exit(0)

cutoff = datetime.now(timezone.utc) - timedelta(hours=KEEP_HOURS)
kept = []
pruned = 0
with open(HISTORY_FILE, "r") as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            entry = json.loads(line)
            ts = datetime.fromisoformat(entry["timestamp"])
            if ts > cutoff:
                kept.append(line)
            else:
                pruned += 1
        except (json.JSONDecodeError, KeyError):
            continue

with open(HISTORY_FILE, "w") as f:
    for line in kept:
        f.write(line + "\n")

if pruned > 0:
    print(f"[prune] Removed {pruned} entries older than {KEEP_HOURS}h. Kept {len(kept)}.")
else:
    print(f"[prune] No entries to prune. Kept {len(kept)}.")
