#!/usr/bin/env python3
"""Persistent gpsd watcher - keeps a subscription alive and caches the latest TPV."""
import json, socket, os, sys

GPSD_HOST = "127.0.0.1"
GPSD_PORT = 2947
CACHE_FILE = "/tmp/gpsd-last-tpv.json"

sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
sock.settimeout(30)
sock.connect((GPSD_HOST, GPSD_PORT))
sock.sendall(b'?WATCH={"enable":true,"json":true}\n')

buf = b""
while True:
    try:
        chunk = sock.recv(4096)
        if not chunk:
            break
        buf += chunk
        while b"\n" in buf:
            line, buf = buf.split(b"\n", 1)
            line = line.strip()
            if not line or not line.startswith(b"{"):
                continue
            try:
                d = json.loads(line.decode())
                if d.get("class") == "TPV" and d.get("mode", 0) >= 2:
                    with open(CACHE_FILE, "w") as f:
                        json.dump(d, f)
                    # Also update location.json if it exists
                    loc_path = os.path.expanduser("~/.hermes/location.json")
                    lat = d.get("lat")
                    lon = d.get("lon")
                    if lat and lon:
                        cache = {
                            "status": "active",
                            "timestamp": d.get("time", ""),
                            "lat": lat,
                            "lon": lon,
                            "alt": d.get("alt"),
                            "speed": d.get("speed"),
                            "mode": d.get("mode"),
                        }
                        with open(loc_path, "w") as f:
                            json.dump(cache, f, indent=2)
            except (json.JSONDecodeError, KeyError):
                pass
    except socket.timeout:
        continue
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        break

sock.close()
