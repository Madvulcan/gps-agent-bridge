#!/usr/bin/env python3
"""
gpsloc - Read current GPS coordinates from a local gpsd daemon.

Usage:
    gpsloc              # Print lat/lon/alt/speed as JSON (default)
    gpsloc --human      # Print human-readable location
    gpsloc --lat        # Print latitude only
    gpsloc --lon        # Print longitude only
    gpsloc --latlon     # Print "lat,lon" (for maps URLs, etc.)
    gpsloc --tpv        # Print full TPV JSON from gpsd (for scripts)

Requires: gpsd running on localhost:2947
"""

import sys
import json
import socket
import time

GPSD_HOST = "127.0.0.1"
GPSD_PORT = 2947
TIMEOUT = 5
CACHE_TIMEOUT = 700  # 11+ minutes to cover the 10-min max interval
TPV_CACHE = "/tmp/gpsd-last-tpv.json"
TPV_CACHE_MAX_AGE = 700  # seconds - use cached TPV if younger than this


def get_cached_tpv():
    """Read the last TPV from the persistent gpsd-watcher cache."""
    import os
    if not os.path.exists(TPV_CACHE):
        return None
    try:
        mtime = os.path.getmtime(TPV_CACHE)
        age = time.time() - mtime
        if age > TPV_CACHE_MAX_AGE:
            return None  # stale
        with open(TPV_CACHE) as f:
            return json.load(f)
    except (json.JSONDecodeError, OSError):
        return None


def get_gps_data(timeout=None):
    """Connect to gpsd and get the latest TPV report.
    
    If timeout is None, uses CACHE_TIMEOUT (long wait for UDP sources).
    If timeout is an int, uses that specific timeout.
    """
    actual_timeout = timeout if timeout is not None else CACHE_TIMEOUT
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(actual_timeout)
    sock.connect((GPSD_HOST, GPSD_PORT))

    # Request JSON watch mode
    sock.sendall(b'?WATCH={"enable":true,"json":true}\n')

    # Read responses until we get a TPV report
    buf = b""
    while True:
        chunk = sock.recv(4096)
        if not chunk:
            break
        buf += chunk
        for line in buf.split(b"\n"):
            if line.startswith(b'{"class":"TPV"'):
                sock.close()
                return json.loads(line.decode("utf-8", errors="replace"))
        buf = b""

    sock.close()
    return None


def main():
    args = sys.argv[1:]

    # First try the persistent cache (instant, no gpsd connection needed)
    data = get_cached_tpv()
    if data is not None:
        # Got cached TPV - use it directly
        pass
    else:
        # No cache or stale - fall back to connecting to gpsd
        try:
            data = get_gps_data()
        except (ConnectionRefusedError, socket.timeout, OSError) as e:
            print(json.dumps({"error": str(e), "host": GPSD_HOST, "port": GPSD_PORT}))
            sys.exit(1)

    if data is None:
        print(json.dumps({"error": "No TPV data received from gpsd"}))
        sys.exit(1)

    if "--lat" in args:
        print(data.get("lat", ""))
    elif "--lon" in args:
        print(data.get("lon", ""))
    elif "--latlon" in args:
        print(f"{data.get('lat','')},{data.get('lon','')}")
    elif "--tpv" in args:
        # Raw TPV JSON for programmatic consumers (location-updater, etc.)
        print(json.dumps(data))
    elif "--human" in args:
        lat = data.get("lat", "?")
        lon = data.get("lon", "?")
        alt = data.get("alt", "?")
        speed = data.get("speed", "?")
        track = data.get("track", "?")
        mode = data.get("mode", 0)
        eph = data.get("eph", "?")
        mode_str = {0: "no fix", 1: "no fix", 2: "2D", 3: "3D"}.get(mode, "?")
        print(f"Latitude:  {lat}")
        print(f"Longitude: {lon}")
        print(f"Altitude:  {alt} m")
        print(f"Speed:     {speed} m/s")
        print(f"Heading:   {track}°")
        print(f"Accuracy:  {eph} m")
        print(f"Fix:       {mode_str}")
    else:
        # Default: output full JSON (pretty-printed for humans)
        print(json.dumps(data, indent=2))


if __name__ == "__main__":
    main()
